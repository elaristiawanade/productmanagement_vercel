# ─── Server ────────────────────────────────────────────────────
SERVER_PORT=4000

# ─── Database ──────────────────────────────────────────────────
SPRING_DATASOURCE_URL=jdbc:postgresql://127.0.0.1:5432/product_tracker
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=your_db_password

# ─── JWT ───────────────────────────────────────────────────────
# Use a long, random string (min 32 chars recommended)
APP_JWT_SECRET=replace_with_strong_random_secret
# Token expiry in milliseconds: 604800000 = 7 days
APP_JWT_EXPIRATION=604800000

# ─── CORS ──────────────────────────────────────────────────────
# Same-origin deployment (frontend served by Spring Boot): same as server URL
APP_CORS_ORIGIN=http://localhost:4000

# ─── File uploads ──────────────────────────────────────────────
UPLOAD_DIR=./uploads

# ─── Microsoft Teams (optional) ────────────────────────────────
TEAMS_WEBHOOK_URL=

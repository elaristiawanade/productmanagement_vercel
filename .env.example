# ── Vercel / Node.js Backend ──────────────────────────────────────────────────
# Copy this file to .env for local development

# PostgreSQL connection string
# Local:   DATABASE_URL=postgresql://postgres:yourpass@localhost:5432/product_tracker
# Neon:    DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/product_tracker?sslmode=require
# Supabase: DATABASE_URL=postgresql://postgres:pass@db.xxxx.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/product_tracker

# JWT secret — use a long random string (min 32 chars)
JWT_SECRET=replace_with_a_very_long_random_secret_string_here

# Token expiry (e.g. 7d, 30d, 1h)
JWT_EXPIRES_IN=7d

# CORS — set to your Vercel domain in production, e.g. https://your-app.vercel.app
# Leave as * for development
CORS_ORIGIN=*

# Local API port (not used on Vercel)
PORT=4000

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
# Only needed when running the frontend dev server locally against a remote API.
# Leave UNSET on Vercel — the frontend will use relative /api paths automatically.
# VITE_API_URL=https://your-app.vercel.app/api
